# 这份文件是「服务器 .env 的模板」。
# 本地不需要 .env —— 本地只用来写代码，不跑运行时。
# 服务器上的实际 .env 在 /opt/makeup-mate/backend/.env，不要 commit。

# ---------- 服务 ----------
APP_NAME=makeup-mate-backend
APP_VERSION=0.1.0
APP_ENV=production
LOG_LEVEL=INFO

# ---------- 数据库（阿里云 RDS PostgreSQL） ----------
DATABASE_URL=postgresql+psycopg2://makeup_mate:PASSWORD@pgm-bp1x5ddtn527wd26.pg.rds.aliyuncs.com:5432/makeup_mate

# ---------- AI（Qwen-VL-Max；走 DashScope 原生 或 OpenAI 兼容中转都行） ----------
DASHSCOPE_API_KEY=sk-your-key
# 默认走阿里 DashScope 原生：
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 或走 openai-next 中转：
# DASHSCOPE_BASE_URL=https://api.openai-next.com/v1
QWEN_VL_MODEL=qwen-vl-max

# ---------- 公网回调地址（给 Qwen 拉图用） ----------
# 必填。Qwen 会请求 {PUBLIC_BASE_URL}/api/media/{id}/raw 拉图
PUBLIC_BASE_URL=http://121.43.144.91:8080

# ---------- CORS ----------
# 走 Nginx 反代，前后端同源，留几个安全的兜底就行
CORS_ORIGINS=http://121.43.144.91:8080

# ---------- 默认用户 ----------
DEFAULT_USER_ID=user_demo

# ---------- 文件存储 ----------
STORAGE_DIR=/opt/makeup-mate/backend/storage/tmp
