# ---------- 服务 ----------
APP_NAME=makeup-mate-backend
APP_VERSION=0.1.0
APP_ENV=local
LOG_LEVEL=INFO

# ---------- 数据库 ----------
# 本地开发默认 SQLite
DATABASE_URL=sqlite:///./storage/makeup_mate.db

# 部署到 ECS + RDS 时改为：
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@your-rds-endpoint:3306/makeup_mate?charset=utf8mb4
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@your-rds-endpoint:5432/makeup_mate

# ---------- CORS ----------
# 多个域名以逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- 默认用户 ----------
# 第一阶段不做真实登录
DEFAULT_USER_ID=user_demo

# ---------- 文件存储 ----------
STORAGE_DIR=./storage/tmp
